function CreatePlayerTab()
	if CurrentTab then 
		if CurrentTab.Name == "PlayerTab" then return
		else
			print(CurrentTab)
			CurrentTab:Destroy() CurrentTab = nil
		end 
	end
	local newframe = Instance.new("Frame")
	newframe.Parent = CompletePlayerTab
	newframe.Name = "PlayerTab"
	newframe.AnchorPoint = Vector2.new(.5,.5)
	newframe.Position = UDim2.new(0.5,0,0.5,0)
	newframe.Size = UDim2.new(.95,0,0,210)
	local Left = Instance.new("Frame")
	Left.Parent = newframe
	Left.Name = "LeftSide"
	Left.Size = UDim2.new(0,300,1,0)

	--buttons and toggles
	local sprint = Instance.new("TextButton")
	sprint.Name = "SprintButton"
	sprint.Parent = Left
	sprint.Position = UDim2.new(.05,0,.05,0)
	sprint.Size = UDim2.new(0,180,0,50)
	sprint.Text = "Sprint"
	sprint.TextScaled = true
	sprint.TextColor3 = Color3.new(1,0,0)
	local stroke = Instance.new("UIStroke")
	stroke.Parent = sprint
	stroke.Thickness = 4

	local slider = Instance.new("Frame")
	slider.Name = "Slider"
	slider.Parent = Left
	slider.Position = UDim2.new(0.05,0,.4,0)
	slider.Size = UDim2.new(0,270,0,20)
	slider.BackgroundColor3 = Color3.fromRGB(112,112,112)
	local slidebtn = Instance.new("TextButton")
	slidebtn.Name = "SlideButton"
	slidebtn.Parent = slider
	slidebtn.AnchorPoint = Vector2.new(0,.5)
	slidebtn.Position = UDim2.new(0,0,.5,0)
	slidebtn.Size = UDim2.new(0,30,0,50)
	slidebtn.Text = ""

	local sprintspeed = 2.45

	task.spawn(function() -- slider logic
		local db = false
		local step = 0.01
		local percentage = 0

		local function snap(number,factor)
			if factor == 0 then
				return number
			else
				return math.floor(number/factor+0.5)*factor

			end
		end

		UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				db = false
			end
		end)

		slidebtn.MouseButton1Down:Connect(function()
			db = true
		end)

		Runservice.RenderStepped:Connect(function()
			if db then
				local MousePos = UIS:GetMouseLocation().X
				local BtnPos = slidebtn.Position
				local FrameSize = slider.AbsoluteSize.X
				local FramePos = slider.AbsolutePosition.X
				local pos = snap((MousePos-FramePos)/FrameSize,step)
				percentage = math.clamp(pos,0,1)
				slidebtn.Position = UDim2.new(percentage,-12,BtnPos.Y.Scale,BtnPos.Y.Offset)
			end
		end)

		slidebtn.Changed:Connect(function()
			local scale = slidebtn.Position.X.Scale
			local minVal = 2.45
			local maxVal = 4.45
			local value = minVal + (maxVal - minVal) * scale
			local rounded = math.floor(value * 100) / 100 -- Round to 2 decimal places
			slidebtn.Text = tostring(rounded)
			sprintspeed = rounded
		end)
	end)

	task.spawn(function() -- main run logic
		local UIS = game:GetService("UserInputService")
		local RunService = game:GetService("RunService")

		-- Helper function to get sprinting NumberValue
		local function getSprintingValue()
			local playersFolder = workspace:FindFirstChild("Players")
			if not playersFolder then return nil end

			local targetModel = nil
			for _, model in ipairs(playersFolder:GetDescendants()) do
				if model:IsA("Model") and model:GetAttribute("Username") == "TheyWillBurnToo" then
					targetModel = model
					break
				end
			end

			if not targetModel then return nil end

			local speedMultipliers = targetModel:FindFirstChild("SpeedMultipliers")
			if not speedMultipliers then return nil end

			local sprinting = speedMultipliers:FindFirstChild("Sprinting")
			if sprinting and sprinting:IsA("NumberValue") then
				return sprinting
			end

			return nil
		end


		local sprintingValue = getSprintingValue()

		local function stopHeartbeat()
			if heartbeatConn then
				heartbeatConn:Disconnect()
				heartbeatConn = nil
			end
			if sprintingValue then
				sprintingValue.Value = 1 -- reset sprint speed when stopping
				runTrack:Stop()
			end
		end

		local function startHeartbeat()
			stopHeartbeat() -- safety first

			sprintingValue = getSprintingValue()
			if not sprintingValue then return end

			heartbeatConn = RunService.Heartbeat:Connect(function()
				if not isRunning or Shutdown == true then
					stopHeartbeat()
					return
				end



				-- Check if Left Shift is held
				if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
					sprintingValue.Value = sprintspeed
					runTrack:Play()
				else
					sprintingValue.Value = 1
					runTrack:Stop()
				end
			end)
		end

		sprint.MouseButton1Click:Connect(function()
			isRunning = not isRunning
			sprint.TextColor3 = isRunning and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)

			if isRunning and Shutdown == false then
				startHeartbeat()
			else
				stopHeartbeat()
			end
		end)
	end)

	PlrTab = newframe
	CurrentTab = newframe
end

