			ingameFolder = ingameFolder:FindFirstChild("Ingame")
			if not ingameFolder then return end

			if cleanup.Items.conn then
				cleanup.Items.conn:Disconnect()
				cleanup.Items.conn = nil
			end

			-- Initial tool scan
			for _, obj in ipairs(ingameFolder:GetDescendants()) do
				if obj:IsA("Tool") then
					if state then
						applyHighlight(obj, Color3.fromRGB(255, 165, 0), Color3.new(0.7, 0.7, 0)) -- Orange for items
					else
						removeHighlights(obj)
					end
				end
			end

