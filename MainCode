		local function toggleSurvivors(state)
			local folder = workspace:FindFirstChild("Players") and workspace.Players:FindFirstChild("Survivors")
			if not folder then return end

			local function ApplyDynamicHighlight(model)
				if model.Name == "Elliot" then
					applyHighlight(model, Color3.fromRGB(0, 255, 0), Color3.new(0, 0.4, 0))
				elseif model.Name == "Shedletsky" then
					applyHighlight(model, Color3.fromRGB(255, 255, 0), Color3.new(0.7, 0.7, 0))
				else
					applyHighlight(model, Color3.fromRGB(0, 0, 255), Color3.new(0, 0, 0.4))
				end

				if model then
					local Humanoid = model:FindFirstChildOfClass("Humanoid")
					if Humanoid then
						Humanoid.Died:Connect(function()
							removeHighlights(model)
						end)
					else
						model.Destroying:Connect(function()
							removeHighlights(model)
						end)
					end
				end
			end

			for _, child in pairs(folder:GetChildren()) do
				if state then
					ApplyDynamicHighlight(child)
				else
					removeHighlights(child)
				end
			end



			if cleanup.Survivors.conn then
				cleanup.Survivors.conn:Disconnect()
			end


			workspace:WaitForChild("Players"):WaitForChild("Survivors").DescendantAdded:Connect(function(descendant)
				if descendant:IsA("Model") and descendant:FindFirstChildOfClass("Humanoid") and state and toggles.Survivors == true then
					ApplyDynamicHighlight(descendant)
					local h = descendant:FindFirstChildOfClass("Humanoid")
					if h then
						h.Died:Connect(function()
							removeHighlights(descendant)
						end)
					end
				end
			end)

			if state then
				cleanup.Survivors.conn = folder.ChildRemoved:Connect(function(child)
					removeHighlights(child)
				end)
			else
				cleanup.Survivors.conn = nil
			end
		end

